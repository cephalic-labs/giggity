# =============================================================================
# Giggity — root .env (read by docker compose)
# Copy this file and fill in the values before running:
#   docker compose up -d
# =============================================================================

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Admin bootstrap ───────────────────────────────────────────────────────────
# Comma-separated emails that get ADMIN role on first login
ADMIN_BOOTSTRAP_EMAILS=admin@example.com

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set to your VPS domain or IP when deploying, e.g. http://203.0.113.10:3000
CORS_ALLOW_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL the browser uses to reach the backend.
# For VPS: http://<your-vps-ip>:8000  or  https://api.yourdomain.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── External APIs (optional — mock data used when blank) ─────────────────────
# OpenWeatherMap free tier: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# OpenAQ v3 free tier: https://openaq.org
OPENAQ_API_KEY=

# ── Trigger scheduler ────────────────────────────────────────────────────────
TRIGGER_POLL_MINUTES=5
TRIGGER_COOLDOWN_HOURS=6

# ── Parametric thresholds ────────────────────────────────────────────────────
RAIN_THRESHOLD_MM=70
HEAT_THRESHOLD_C=42
AQI_THRESHOLD=350
FLASH_FLOOD_RAIN_MM=80
FLASH_FLOOD_WIND_KMH=45
LOCKDOWN_DAILY_PROB=0.02
