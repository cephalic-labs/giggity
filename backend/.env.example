# Backend service configuration
DATABASE_URL=sqlite:///./giggity.db
JWT_SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated allowlist for browser origins
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional comma-separated admin bootstrap accounts
ADMIN_BOOTSTRAP_EMAILS=admin@giggity.dev

# --- Automated Trigger Polling ---
# How often the trigger scheduler polls weather/AQI APIs (minutes)
TRIGGER_POLL_MINUTES=5

# OpenWeatherMap API key (free tier works). Leave blank to use realistic mock data.
OPENWEATHER_API_KEY=

# OpenAQ v3 API key (register free at openaq.org). Leave blank to use mock AQI data.
OPENAQ_API_KEY=

# Cooldown window: same zone+trigger type won't re-fire within this many hours
TRIGGER_COOLDOWN_HOURS=6

# Parametric thresholds (can be tuned per pilot)
RAIN_THRESHOLD_MM=70
HEAT_THRESHOLD_C=42
AQI_THRESHOLD=350
FLASH_FLOOD_RAIN_MM=80
FLASH_FLOOD_WIND_KMH=45
LOCKDOWN_DAILY_PROB=0.02
